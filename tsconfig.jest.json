{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "types": ["jest", "node"],
    "paths": {
      "~/config": ["./src/__mocks__/config.ts"],
      "~/*": ["./src/*"]
    }
  },
  "exclude": []
}
